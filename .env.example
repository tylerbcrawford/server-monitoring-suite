# Server Monitoring Suite Configuration
# Copy to .env and fill in your values

# Discord webhook for alerts (required for container-health-monitor, resource-alert, cert-expiry-check)
ADMIN_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: certbot binary path (for cert-expiry-check.sh)
CERTBOT_BIN=/usr/bin/certbot

# Optional: custom paths for log-health-check.sh
# DOWNLOAD_LOG=/path/to/downloads/nzbget.log
# APP_LOG_DIR=/path/to/app/logs
# EXTRA_LOG_DIRS="/path/to/script/logs /path/to/other/logs"

# Optional: *arr services to monitor (space-separated container names)
# ARR_SERVICES="sonarr radarr prowlarr readarr lidarr"
